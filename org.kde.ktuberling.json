                    }
                }
            ]
        },
        {
            "name": "ktuberling",
            "buildsystem": "cmake-ninja",
            "config-opts": [
                "-DCMAKE_BUILD_TYPE=RelWithDebInfo"
            ],
            "builddir": true,
            "sources": [
                {
                    "type": "archive",
                    "url": "https://download.kde.org/stable/release-service/25.12.2/src/ktuberling-25.12.2.tar.xz",
                    "sha256": "e47ce8f10c12117cea28bf4f6a92962df8ef9715310f90c250d396dee5f95229",
