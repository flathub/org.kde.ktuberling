{
    "id": "org.kde.ktuberling",
    "runtime": "org.kde.Platform",
    "runtime-version": "6.10",
    "sdk": "org.kde.Sdk",
    "command": "ktuberling",
    "rename-icon": "ktuberling",
    "finish-args": [
        "--share=ipc",
        "--socket=cups",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--socket=pulseaudio",
        "--device=dri",
        "--filesystem=xdg-config/kdeglobals:ro"
    ],
    "modules": [
